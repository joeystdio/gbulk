<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="gbulk"
           Language="1033"
           Version="0.1.0"
           Manufacturer="Jo Jo"
           UpgradeCode="12345678-1234-1234-1234-123456789012">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Bulk git operations tool" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of gbulk is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="gbulk" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- Add to PATH -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <UI>
      <UIRef Id="WixUI_InstallDir" />
    </UI>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="gbulk">
          <Component Id="gbulk.exe" Guid="12345678-1234-1234-1234-123456789013" Win64="yes">
            <File Id="gbulk.exe"
                  Name="gbulk.exe"
                  Source="target\release\gbulk.exe"
                  KeyPath="yes" />
            <Environment Id="PATH"
                         Name="PATH"
                         Value="[INSTALLFOLDER]"
                         Permanent="no"
                         Part="last"
                         Action="set"
                         System="yes" />
          </Component>

          <Component Id="README.md" Guid="12345678-1234-1234-1234-123456789014" Win64="yes">
            <File Id="README.md"
                  Name="README.md"
                  Source="README.md"
                  KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <ComponentGroup Id="ProductComponents">
      <ComponentRef Id="gbulk.exe" />
      <ComponentRef Id="README.md" />
    </ComponentGroup>
  </Product>
</Wix>
